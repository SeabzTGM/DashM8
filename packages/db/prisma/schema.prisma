generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Staff {
  id                   String   @id @default(cuid())
  servicem8StaffUuid   String?  @unique
  firstName            String
  lastName             String
  email                String?
  hourlyCostRate       Float?
  hourlyBillableRate   Float?

  jobs                 Job[]
  staffKpiSnapshots    StaffKpiSnapshot[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Customer {
  id                    String   @id @default(cuid())
  name                  String
  servicem8CompanyUuid  String?  @unique

  jobs                  Job[]
  invoices              Invoice[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Job {
  id                 String   @id @default(cuid())
  servicem8JobUuid   String?  @unique

  title              String
  status             String
  completedAt        DateTime?

  assignedStaffId    String?
  assignedStaff      Staff?   @relation(fields: [assignedStaffId], references: [id])

  customerId         String?
  customer           Customer? @relation(fields: [customerId], references: [id])

  actualRevenue      Float?
  actualMaterialCost Float?
  grossMarginAmount  Float?
  grossMarginPct     Float?

  materials          JobMaterial[]
  invoices           Invoice[]
  statusHistory      JobStatusHistory[]
  attentionFlags     JobAttentionFlag[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model JobMaterial {
  id         String  @id @default(cuid())

  jobId      String
  job        Job     @relation(fields: [jobId], references: [id])

  name       String
  quantity   Float
  unitCost   Float
  totalCost  Float
  totalSell  Float?

  createdAt  DateTime @default(now())
}

model Invoice {
  id              String   @id @default(cuid())
  xeroInvoiceId   String?  @unique

  jobId           String?
  job             Job?     @relation(fields: [jobId], references: [id])

  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])

  status          String
  paymentStatus   String   @default("PENDING")

  total           Float
  amountPaid      Float    @default(0)
  amountDue       Float    @default(0)

  issueDate       DateTime?
  dueDate         DateTime?

  payments        Payment[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())

  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])

  paymentDate   DateTime
  amount        Float

  createdAt     DateTime @default(now())
}

model JobStatusHistory {
  id        String   @id @default(cuid())

  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])

  status    String
  changedAt DateTime @default(now())
}

model JobAttentionFlag {
  id         String   @id @default(cuid())

  jobId      String
  job        Job      @relation(fields: [jobId], references: [id])

  reason     String
  resolved   Boolean  @default(false)

  createdAt  DateTime @default(now())
}

model DailyKpiSnapshot {
  id                    String   @id @default(cuid())

  date                  DateTime
  jobsCompleted         Int
  revenue               Float
  materialCost          Float
  grossMargin           Float

  createdAt             DateTime @default(now())
}

model StaffKpiSnapshot {
  id            String   @id @default(cuid())

  date          DateTime
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id])

  jobsCompleted Int
  revenue       Float
  margin        Float

  createdAt     DateTime @default(now())
}