generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  QUOTE
  WORK_ORDER
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  AUTHORISED
  PAID
  VOIDED
  DELETED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  VOIDED
}

model Staff {
  id                 String   @id @default(cuid())
  servicem8StaffUuid String?  @unique
  firstName          String?
  lastName           String?
  email              String?
  isActive           Boolean  @default(true)
  hourlyCostRate     Decimal?
  hourlyBillableRate Decimal?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  assignedJobs       Job[]
  metrics            StaffMetricSnapshot[]
}

model Customer {
  id                   String   @id @default(cuid())
  servicem8CompanyUuid String?  @unique
  xeroContactId        String?  @unique
  name                 String
  email                String?
  phone                String?
  suburb               String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  jobs                 Job[]
  invoices             Invoice[]
}

model Job {
  id                  String    @id @default(cuid())
  servicem8JobUuid    String    @unique
  generatedJobNumber  String?
  title               String?
  description         String?
  status              JobStatus
  customerId          String?
  assignedStaffId     String?
  createdAtSource     DateTime?
  scheduledStart      DateTime?
  completedAt         DateTime?
  actualMaterialCost  Decimal?
  actualRevenue       Decimal?
  grossMarginAmount   Decimal?
  grossMarginPct      Decimal?
  syncUpdatedAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  customer            Customer? @relation(fields: [customerId], references: [id])
  assignedStaff       Staff?    @relation(fields: [assignedStaffId], references: [id])
  materials           JobMaterial[]
  invoices            Invoice[]
}

model JobMaterial {
  id                    String   @id @default(cuid())
  jobId                 String
  servicem8MaterialUuid String?  @unique
  name                  String
  description           String?
  quantity              Decimal
  unitCost              Decimal?
  unitSell              Decimal?
  totalCost             Decimal?
  totalSell             Decimal?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  job                   Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Invoice {
  id             String        @id @default(cuid())
  xeroInvoiceId  String?       @unique
  invoiceNumber  String?
  status         InvoiceStatus
  paymentStatus  PaymentStatus @default(PENDING)
  customerId     String?
  jobId          String?
  issueDate      DateTime?
  dueDate        DateTime?
  total          Decimal?
  amountPaid     Decimal?
  amountDue      Decimal?
  reference      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer       Customer?     @relation(fields: [customerId], references: [id])
  job            Job?          @relation(fields: [jobId], references: [id])
  payments       Payment[]
}

model Payment {
  id            String   @id @default(cuid())
  xeroPaymentId String?  @unique
  invoiceId     String
  paymentDate   DateTime
  amount        Decimal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model DailyMetricSnapshot {
  id                    String   @id @default(cuid())
  snapshotDate          DateTime @unique
  totalJobsCompleted    Int      @default(0)
  totalRevenueInvoiced  Decimal  @default(0)
  totalCashCollected    Decimal  @default(0)
  totalMaterialCost     Decimal  @default(0)
  totalAmountOutstanding Decimal @default(0)
  totalOverdueAmount    Decimal  @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model StaffMetricSnapshot {
  id                  String   @id @default(cuid())
  snapshotDate        DateTime
  staffId             String
  jobsCompleted       Int      @default(0)
  revenueInvoiced     Decimal  @default(0)
  cashCollected       Decimal  @default(0)
  materialCost        Decimal  @default(0)
  grossMarginAmount   Decimal  @default(0)
  jobsAwaitingPayment Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  staff               Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([snapshotDate, staffId])
}
